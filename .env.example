# PostgreSQL connections. DATABASE_URL is still supported as a legacy auth fallback.
AUTH_DATABASE_URL=postgres://username:password@localhost:5432/evd
ANALYTICS_DATABASE_URL=postgres://username:password@localhost:5433/evd_analytics
SKIP_DB_SCHEMA_SYNC=false
PORT=4000

# Rate limiting (per IP). Disabled automatically when RATE_LIMIT_DISABLED=true.
# Defaults: 1000/min in development, 100/min in production.
RATE_LIMIT_MAX=1000
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_DISABLED=true

BETTER_AUTH_SECRET=your-secret-key-here
# Public URL of this API for Better Auth callbacks and generated links.
BETTER_AUTH_URL=http://localhost:4000
TRUSTED_ORIGINS=http://localhost:4000,http://localhost:3000
COOKIE_DOMAIN=localhost

# Dashboard URL used for password reset links when x-evd-app-id=dashboard.
DASHBOARD_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Disk-backed uploads.
UPLOAD_DIR=uploads

# SMTP. When SMTP_HOST is unset, reset links are logged instead of sent.
MAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_FROM_NAME=DHA EVD
SUPPORT_EMAIL=support@evd.local

# SMS notifications.
SMS_PROVIDER=africastalking
SMS_USERNAME=your-africastalking-username
SMS_API_KEY=your-sms-api-key
SMS_SENDER_ID=DHAEVD
