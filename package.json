{
  "name": "evd-server",
  "version": "3.1.0",
  "description": "Focused backend API for the DHA EVD dashboard stack",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest run --inspect-brk",
    "test:e2e": "vitest run --config ./vitest.config.ts",
    "seed:admin": "npx tsx src/scripts/seed-admin.ts",
    "seed:admin:prod": "node dist/src/scripts/seed-admin.js"
  },
  "dependencies": {
    "@better-auth/kysely-adapter": "^1.6.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.5",
    "@opentelemetry/api": "^1.9.1",
    "@thallesp/nestjs-better-auth": "^2.6.0",
    "@types/multer": "^2.1.0",
    "@types/nodemailer": "^8.0.0",
    "africastalking": "^0.7.9",
    "better-auth": "^1.6.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "kysely": "^0.28.8",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "pg-mem": "^3.0.14",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.4"
  }
}
